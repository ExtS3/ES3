# Local server
APP_PORT=8000

# PostgreSQL container
DB_HOST=db
DB_PORT=5432
DB_PUBLISHED_PORT=5432
DB_USER=example_db_user
DB_PASSWORD=example_db_password
DB_NAME=example_db_name

# Suppressor vector PostgreSQL container
PGVECTOR_DB_HOST=vector-db
PGVECTOR_DB_PORT=5432
PGVECTOR_DB_PUBLISHED_PORT=5433
PGVECTOR_DB_USER=vector_db_user
PGVECTOR_DB_PASSWORD=vector_db_password
PGVECTOR_DB_NAME=vector_db
PGVECTOR_TABLE=public.es3_vector
EMBEDDING_DIM=1024
PGVECTOR_MATCH_THRESHOLD=0
PGVECTOR_MATCH_COUNT=10

# Nexus container
NEXUS_BASE_URL=http://nexus:8081
NEXUS_PUBLISHED_PORT=8081
NEXUS_REPOSITORY=extension-demo
NEXUS_USERNAME=example_nexus_user
NEXUS_PASSWORD=example_nexus_password
NEXUS_STORAGE_LIMIT_BYTES=

# Suppressor container
SUPPRESSOR_PRIVATE_IP=suppressor
SUPPRESSOR_PORT=8001
SUPPRESSOR_PUBLISHED_PORT=8001
EXTERNAL_RUNNER_MODE=file

# Local fallback behavior
ENABLE_LOCAL_LIBRARY_FALLBACK=true

# AI 판단 모듈 (ai_judgment)
ENABLE_AI_JUDGMENT=true
LOCAL_LLM_URL=http://localhost:11434/api/chat
LOCAL_LLM_MODEL=qwen2.5:1.5b-instruct-q4_K_M
AI_JUDGMENT_MAX_TOKENS=1024
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.1
SLACK_WEBHOOK_URL=
DASHBOARD_BASE_URL=http://localhost:8000
OLLAMA_KEEP_ALIVE=5m
